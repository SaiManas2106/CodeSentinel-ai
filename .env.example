########################################
# App
########################################
APP_NAME=CodeSentinel AI
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

########################################
# Database (PostgreSQL + pgvector)
########################################
POSTGRES_DB=YOUR_VALUE_HERE
POSTGRES_USER=YOUR_VALUE_HERE
POSTGRES_PASSWORD=YOUR_VALUE_HERE
POSTGRES_HOST=postgresql
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://YOUR_VALUE_HERE:YOUR_VALUE_HERE@postgresql:5432/YOUR_VALUE_HERE

########################################
# Redis
########################################
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=YOUR_VALUE_HERE
REDIS_URL=redis://:YOUR_VALUE_HERE@redis:6379/0

########################################
# Qdrant
########################################
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_API_KEY=YOUR_VALUE_HERE
QDRANT_COLLECTION=codesentinel_chunks

########################################
# Kafka
########################################
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_PR_REVIEW_TOPIC=pr-review-requests
KAFKA_CONSUMER_GROUP=review-workers

########################################
# MongoDB
########################################
MONGO_ROOT_USERNAME=YOUR_VALUE_HERE
MONGO_ROOT_PASSWORD=YOUR_VALUE_HERE
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_DATABASE=codesentinel
MONGO_URI=mongodb://YOUR_VALUE_HERE:YOUR_VALUE_HERE@mongodb:27017/codesentinel?authSource=admin

########################################
# AWS / S3 / MinIO
########################################
AWS_ACCESS_KEY_ID=YOUR_VALUE_HERE
AWS_SECRET_ACCESS_KEY=YOUR_VALUE_HERE
AWS_REGION=us-east-1
S3_BUCKET_NAME=YOUR_VALUE_HERE
MINIO_ROOT_USER=YOUR_VALUE_HERE
MINIO_ROOT_PASSWORD=YOUR_VALUE_HERE
MINIO_ENDPOINT=http://minio:9000
MLFLOW_S3_BUCKET=YOUR_VALUE_HERE
MLFLOW_S3_ENDPOINT_URL=http://minio:9000

########################################
# OpenAI / Cohere / HuggingFace
########################################
OPENAI_API_KEY=YOUR_VALUE_HERE
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
COHERE_API_KEY=YOUR_VALUE_HERE
HUGGINGFACE_TOKEN=YOUR_VALUE_HERE
CODEBERT_MODEL_NAME=microsoft/codebert-base

########################################
# GitHub OAuth + GitHub App
########################################
GITHUB_CLIENT_ID=YOUR_VALUE_HERE
GITHUB_CLIENT_SECRET=YOUR_VALUE_HERE
GITHUB_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/auth/github/callback
GITHUB_APP_ID=YOUR_VALUE_HERE
GITHUB_APP_PRIVATE_KEY=YOUR_VALUE_HERE
GITHUB_WEBHOOK_SECRET=YOUR_VALUE_HERE

########################################
# MLflow / W&B
########################################
MLFLOW_TRACKING_URI=http://mlflow:5000
WANDB_API_KEY=YOUR_VALUE_HERE
WANDB_PROJECT=codesentinel-ai
WANDB_ENTITY=YOUR_VALUE_HERE

########################################
# LangSmith / Sentry
########################################
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=YOUR_VALUE_HERE
LANGCHAIN_PROJECT=CodeSentinel
SENTRY_DSN=YOUR_VALUE_HERE
SENTRY_TRACES_SAMPLE_RATE=0.2

########################################
# JWT / Auth
########################################
JWT_SECRET_KEY=YOUR_VALUE_HERE
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=14
NEXTAUTH_SECRET=YOUR_VALUE_HERE
NEXTAUTH_URL=http://localhost:3000

########################################
# CORS
########################################
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

########################################
# Grafana
########################################
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=YOUR_VALUE_HERE
